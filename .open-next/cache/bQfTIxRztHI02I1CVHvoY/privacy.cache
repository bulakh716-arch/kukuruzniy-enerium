3:I[4707,[],\"\"]\n4:I[6423,[],\"\"]\n6:I[1785,[\"185\",\"static/chunks/app/layout-afc0aad3ee7a9a8e.js\"],\"default\"]\n5:T5a1,{\"@context\":\"https://schema.org\",\"@graph\":[{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Enerium\",\"url\":\"https://enerium.app\",\"logo\":\"https://enerium.app/logo.png\",\"description\":\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\",\"email\":\"hello@enerium.app\",\"contactPoint\":[{\"@type\":\"ContactPoint\",\"contactType\":\"customer support\",\"email\":\"hello@enerium.app\",\"availableLanguage\":[\"en\"]},{\"@type\":\"ContactPoint\",\"contactType\":\"privacy support\",\"email\":\"privacy@enerium.app\",\"availableLanguage\":[\"en\"]},{\"@type\":\"ContactPoint\",\"contactType\":\"legal support\",\"email\":\"legal@enerium.app\",\"availableLanguage\":[\"en\"]}]},{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"Enerium\",\"url\":\"https://enerium.app\",\"description\":\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\",\"inLanguage\":\"en-US\"},{\"@context\":\"https://schema.org\",\"@type\":\"MobileApplication\",\"name\":\"Enerium\",\"url\":\"https://enerium.app\",\"applicationCategory\":\"HealthApplication\",\"operatingSystem\":\"iOS, Android\",\"description\":\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\",\"featureList\":[\"Nutrition Intelligence\",\"Fitness & Activity\",\"Smart Hydration\",\"AI Kitchen\",\"Deep Analytics\"]}]}0:[\"bQfTIxRztHI02I1CVHvoY\",[[[\"\",{\"children\":[\"privacy\",{\"children\":[\"__PAGE__\",{}]}]},\"$undefined\",\"$undefined\",true],[\"\",{\"children\":[\"privacy\",{\"children\":[\"__PAGE__\",{},[[\"$L1\",[\"$\",\"main\",null,{\"className\":\"min-h-screen bg-[#050505] text-white\",\"children\":[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-3xl px-6 py-24\",\"children\":[[\"$\",\"$L2\",null,{}],[\"$\",\"h1\",null,{\"className\":\"font-satoshi text-4xl font-black text-white md:text-5xl\",\"children\":\"Privacy Policy\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-white/30\",\"children\":\"Last updated: April 2026\"}],[\"$\",\"div\",null,{\"className\":\"mt-12 space-y-8 text-sm leading-relaxed text-white/60\",\"children\":[[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-3 font-satoshi text-lg font-bold text-white\",\"children\":\"1. Information We Collect\"}],[\"$\",\"p\",null,{\"children\":\"We collect information you provide directly: account details (email, name), health data (nutrition logs, fitness activity, body metrics), and usage data. We also collect device information and analytics to improve the service.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-3 font-satoshi text-lg font-bold text-white\",\"children\":\"2. How We Use Your Data\"}],[\"$\",\"p\",null,{\"children\":\"Your data is used to provide personalized health recommendations, power AI features (Vision AI, meal planning, adaptive intelligence), sync with health platforms (Apple Health, Google Fit), and improve our service quality.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-3 font-satoshi text-lg font-bold text-white\",\"children\":\"3. Data Storage & Security\"}],[\"$\",\"p\",null,{\"children\":\"All health data is encrypted end-to-end using industry-standard AES-256 encryption. Data is stored on secure servers with strict access controls. We conduct regular security audits and penetration testing.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-3 font-satoshi text-lg font-bold text-white\",\"children\":\"4. Data Sharing\"}],[\"$\",\"p\",null,{\"children\":\"We do not sell, rent, or trade your personal health data to third parties. Data may be shared only with your explicit consent, or when required by law. Third-party integrations (Apple Health, Google Fit) operate under their respective privacy policies.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-3 font-satoshi text-lg font-bold text-white\",\"children\":\"5. AI & Machine Learning\"}],[\"$\",\"p\",null,{\"children\":\"Our AI models process your data on-device when possible. When cloud processing is needed, data is anonymized and encrypted in transit. AI models are not trained on individual user data without explicit opt-in consent.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-3 font-satoshi text-lg font-bold text-white\",\"children\":\"6. Your Rights\"}],[\"$\",\"p\",null,{\"children\":\"You have the right to: access your data, correct inaccurate data, delete your account and all associated data, export your data in standard formats, and opt out of non-essential data processing. Contact us to exercise any of these rights.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-3 font-satoshi text-lg font-bold text-white\",\"children\":\"7. Cookies & Tracking\"}],[\"$\",\"p\",null,{\"children\":\"Our website uses essential cookies for functionality. We use privacy-respecting analytics to understand usage patterns. You can control cookie preferences through your browser settings.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"mb-3 font-satoshi text-lg font-bold text-white\",\"children\":\"8. Contact\"}],[\"$\",\"p\",null,{\"children\":[\"For privacy-related questions or data requests, contact our Data Protection team at \",[\"$\",\"span\",null,{\"className\":\"text-[#B7F46B]\",\"children\":\"privacy@enerium.app\"}]]}]]}]]}]]}]}],null],null],null]},[null,[\"$\",\"$L3\",null,{\"parallelRouterKey\":\"children\",\"segmentPath\":[\"children\",\"privacy\",\"children\"],\"error\":\"$undefin