{"type":"app","meta":{"headers":{"x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/"}},"html":"<!DOCTYPE html><html lang=\"en\" class=\"antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" href=\"/logo.png\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fscreen-vision.PNG&amp;w=384&amp;q=75 1x, /_next/image?url=%2Fscreen-vision.PNG&amp;w=640&amp;q=75 2x\" fetchPriority=\"high\"/><link rel=\"stylesheet\" href=\"/_next/static/css/5311a7fc74388d15.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-616e068a201ad621.js\"/><script src=\"/_next/static/chunks/fd9d1056-b11b2651f33aae7f.js\" async=\"\"></script><script src=\"/_next/static/chunks/117-4f5b424f20efdcae.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-0bca0c59044d953b.js\" async=\"\"></script><script src=\"/_next/static/chunks/480-3706d367077ee5f6.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-a45d1b794697114b.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-afc0aad3ee7a9a8e.js\" async=\"\"></script><link rel=\"preconnect\" href=\"https://api.fontshare.com\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><meta name=\"theme-color\" content=\"#050505\"/><title>Enerium | AI Health App for Nutrition, Fitness &amp; Wellness</title><meta name=\"description\" content=\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\"/><meta name=\"application-name\" content=\"Enerium\"/><link rel=\"author\" href=\"https://enerium.app\"/><meta name=\"author\" content=\"Enerium\"/><link rel=\"manifest\" href=\"/manifest.webmanifest\" crossorigin=\"use-credentials\"/><meta name=\"keywords\" content=\"ai health app,nutrition tracker app,meal planning app,calorie tracker,hydration tracker,fitness tracking app,wellness app,ai meal planner,food recognition app,health analytics app,Enerium\"/><meta name=\"referrer\" content=\"origin-when-cross-origin\"/><meta name=\"creator\" content=\"Enerium\"/><meta name=\"publisher\" content=\"Enerium\"/><meta name=\"robots\" content=\"index, follow\"/><meta name=\"googlebot\" content=\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"/><meta name=\"category\" content=\"Health &amp; Fitness\"/><link rel=\"canonical\" href=\"https://enerium.app\"/><meta name=\"format-detection\" content=\"telephone=no, address=no, email=no\"/><meta name=\"apple-mobile-web-app-capable\" content=\"yes\"/><meta name=\"apple-mobile-web-app-title\" content=\"Enerium\"/><meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\"/><meta property=\"og:title\" content=\"Enerium | AI Health App for Nutrition, Fitness &amp; Wellness\"/><meta property=\"og:description\" content=\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\"/><meta property=\"og:url\" content=\"https://enerium.app\"/><meta property=\"og:site_name\" content=\"Enerium\"/><meta property=\"og:locale\" content=\"en_US\"/><meta property=\"og:image:alt\" content=\"Enerium — Your Health, Reimagined by AI\"/><meta property=\"og:image:type\" content=\"image/png\"/><meta property=\"og:image\" content=\"https://enerium.app/opengraph-image?475b269ee2df9aa5\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Enerium | AI Health App for Nutrition, Fitness &amp; Wellness\"/><meta name=\"twitter:description\" content=\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\"/><meta name=\"twitter:image:alt\" content=\"Enerium — Your Health, Reimagined by AI\"/><meta name=\"twitter:image:type\" content=\"image/png\"/><meta name=\"twitter:image\" content=\"https://enerium.app/twitter-image?25be2af3633d6326\"/><meta name=\"twitter:image:width\" content=\"1200\"/><meta name=\"twitter:image:height\" content=\"630\"/><link rel=\"icon\" href=\"/icon\"/><link rel=\"apple-touch-icon\" href=\"/apple-icon\"/><script defer=\"\" data-domain=\"enerium.app\" src=\"https://plausible.io/js/script.js\"></script><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"bg-void font-inter text-white\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@graph\":[{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Enerium\",\"url\":\"https://enerium.app\",\"logo\":\"https://enerium.app/logo.png\",\"description\":\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\",\"email\":\"hello@enerium.app\",\"contactPoint\":[{\"@type\":\"ContactPoint\",\"contactType\":\"customer support\",\"email\":\"hello@enerium.app\",\"availableLanguage\":[\"en\"]},{\"@type\":\"ContactPoint\",\"contactType\":\"privacy support\",\"email\":\"privacy@enerium.app\",\"availableLanguage\":[\"en\"]},{\"@type\":\"ContactPoint\",\"contactType\":\"legal support\",\"email\":\"legal@enerium.app\",\"availableLanguage\":[\"en\"]}]},{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"Enerium\",\"url\":\"https://enerium.app\",\"description\":\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\",\"inLanguage\":\"en-US\"},{\"@context\":\"https://schema.org\",\"@type\":\"MobileApplication\",\"name\":\"Enerium\",\"url\":\"https://enerium.app\",\"applicationCategory\":\"HealthApplication\",\"operatingSystem\":\"iOS, Android\",\"description\":\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\",\"featureList\":[\"Nutrition Intelligence\",\"Fitness & Activity\",\"Smart Hydration\",\"AI Kitchen\",\"Deep Analytics\"]}]}</script><div aria-hidden=\"true\" class=\"ambient-bg pointer-events-none fixed inset-0 -z-10 overflow-hidden\"><div class=\"ambient-bg__base\"></div><div class=\"ambient-bg__aurora ambient-bg__aurora--1\"></div><div class=\"ambient-bg__aurora ambient-bg__aurora--2\"></div><div class=\"ambient-bg__aurora ambient-bg__aurora--3\"></div><div class=\"ambient-bg__noise\"></div><div class=\"ambient-bg__vignette\"></div></div><canvas aria-hidden=\"true\" class=\"pointer-events-none fixed inset-0 z-[1] mix-blend-screen\"></canvas><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@graph\":[{\"@context\":\"https://schema.org\",\"@type\":\"WebPage\",\"name\":\"Enerium | AI Health App for Nutrition, Fitness & Wellness\",\"url\":\"https://enerium.app\",\"description\":\"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.\",\"inLanguage\":\"en-US\",\"isPartOf\":{\"@type\":\"WebSite\",\"name\":\"Enerium\",\"url\":\"https://enerium.app\"}},{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Is Enerium free to use?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Enerium offers a free tier with core features including calorie tracking, water reminders, and step counting. Premium unlocks AI meal planning, Vision AI food scanning, smart fridge management, and advanced analytics.\"}},{\"@type\":\"Question\",\"name\":\"How does Vision AI food recognition work?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Simply point your camera at any meal or food item. Our computer vision model identifies ingredients in real-time, matches them against our nutrition database of 900,000+ foods, and calculates precise macros — protein, fats, carbs, and calories.\"}},{\"@type\":\"Question\",\"name\":\"Does Enerium sync with Apple Health and Google Fit?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Enerium deeply integrates with Apple HealthKit and Google Fit. Steps, workouts, active minutes, and body metrics sync automatically in both directions.\"}},{\"@type\":\"Question\",\"name\":\"Can I use Enerium for meal planning?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Absolutely. Our AI generates a complete weekly meal plan tailored to your calorie goals, dietary preferences, and the ingredients you already have at home. Each plan includes a ready-to-use shopping list.\"}},{\"@type\":\"Question\",\"name\":\"What is the Smart Fridge feature?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Smart Fridge lets you manage a virtual inventory of your real fridge and pantry. The AI then suggests recipes based on what you have, helping you reduce food waste and eat better without extra shopping.\"}},{\"@type\":\"Question\",\"name\":\"Is my health data private and secure?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Your privacy is our top priority. All health data is encrypted end-to-end and stored securely. We never sell your data to third parties. You can export or delete your data at any time.\"}}]},{\"@context\":\"https://schema.org\",\"@type\":\"ItemList\",\"name\":\"Enerium App Features\",\"description\":\"Five health dimensions powered by AI in the Enerium app\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Nutrition Intelligence\",\"description\":\"Track every calorie and macro with precision. AI-powered food recognition analyzes your meals instantly from a single photo.\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Fitness & Activity\",\"description\":\"Steps, workouts, runs, training videos, and multi-week marathon programs. Synced with Apple Health and Google Fit.\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Smart Hydration\",\"description\":\"Intelligent water tracking with adaptive reminders that escalate based on urgency. Never forget to hydrate.\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"AI Kitchen\",\"description\":\"Smart fridge inventory, AI recipe suggestions from your ingredients, automatic meal planning, and shopping lists.\"},{\"@type\":\"ListItem\",\"position\":5,\"name\":\"Deep Analytics\",\"description\":\"Comprehensive progress tracking with custom date ranges, trend analysis, body metrics, and exportable insights.\"}]}]}</script><main class=\"relative min-h-[100svh] overflow-x-hidden text-white\"><div class=\"fixed top-0 left-0 right-0 h-[2px] z-[60] origin-left\" style=\"background:linear-gradient(90deg, #B7F46B, #6DAE2C);transform:scaleX(0)\"></div><nav class=\"fixed top-0 left-0 right-0 z-50 border-b md:backdrop-blur-xl will-change-transform transition-[background-color,border-color,padding] duration-500 py-5 bg-transparent border-transparent\" style=\"opacity:0;transform:translateY(-100px)\"><div class=\"max-w-7xl mx-auto px-6 flex items-center justify-between\"><a class=\"flex items-center gap-3 group\" href=\"/\"><div class=\"relative w-9 h-9\"><img src=\"/logo.png\" alt=\"Enerium\" class=\"w-full h-full object-contain invert mix-blend-screen transition-all duration-300 group-hover:drop-shadow-[0_0_12px_rgba(183,244,107,0.5)]\"/></div><span class=\"text-xl font-satoshi font-bold tracking-tight\">Enerium</span></a><div class=\"hidden md:flex items-center gap-8\"><a href=\"#features\" class=\"text-sm text-void-800 hover:text-white transition-colors duration-300 font-inter\">Features</a><a href=\"#ai\" class=\"text-sm text-void-800 hover:text-white transition-colors duration-300 font-inter\">AI</a><a href=\"#ecosystem\" class=\"text-sm text-void-800 hover:text-white transition-colors duration-300 font-inter\">Ecosystem</a><a href=\"#download\" class=\"text-sm text-void-800 hover:text-white transition-colors duration-300 font-inter\">Download</a></div><div class=\"flex items-center gap-4\"><a href=\"#download\" class=\"button-primary hidden md:inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold font-inter\">Get Started</a><button class=\"md:hidden relative w-8 h-8 flex flex-col items-center justify-center gap-1.5\" aria-label=\"Toggle menu\"><span class=\"w-5 h-px bg-white transition-all duration-300 \"></span><span class=\"w-5 h-px bg-white transition-all duration-300 \"></span></button></div></div></nav><section class=\"relative min-h-[100svh] overflow-hidden pb-40 transition-colors duration-700 bg-black\"><div class=\"relative z-20 mx-auto flex max-w-5xl flex-col items-center px-6 pt-24 text-center md:pt-32\"><div class=\"flex w-full flex-col items-center\" style=\"transform:none\"><div class=\"hero-reveal flex w-full justify-center\"><div class=\"mb-8 inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 backdrop-blur-md\" style=\"opacity:0;filter:blur(8px);transform:translateY(20px)\"><span class=\"relative flex h-2 w-2\"><span class=\"absolute inline-flex h-full w-full animate-ping rounded-full bg-[#B7F46B] opacity-75\"></span><span class=\"relative inline-flex h-2 w-2 rounded-full bg-[#B7F46B]\"></span></span><span class=\"text-[11px] font-semibold uppercase tracking-[0.2em] text-white/60\">AI Health Platform</span></div></div><div class=\"site-intro__video-shell\" style=\"--frame-reveal-duration:0.8s\"><video class=\"site-intro__video\" src=\"/hero-preloader.mp4\" autoPlay=\"\" muted=\"\" playsInline=\"\" preload=\"auto\" aria-hidden=\"true\"></video></div><div class=\"hero-reveal flex w-full flex-col items-center\"><div class=\"mx-auto max-w-4xl text-center\" style=\"opacity:0;transform:translateY(18px)\"><h1 class=\"font-satoshi text-4xl font-b