dium uppercase tracking-widest text-white/35\">Powered Intelligence</div></div><div class=\"md:pl-10 text-center\"><div class=\"font-satoshi text-2xl font-black text-white md:text-3xl\">24/7</div><div class=\"mt-0.5 text-[10px] font-medium uppercase tracking-widest text-white/35\">Smart Insights</div></div></div></div></div></div><div class=\"pointer-events-none absolute bottom-0 left-0 right-0 z-30 h-64 bg-gradient-to-b from-transparent via-[#050505]/40 to-transparent\"></div></section><div class=\"relative h-40 md:h-56 overflow-hidden\"><div class=\"absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2\" style=\"opacity:0;transform:scale(0.8)\"><div class=\"h-3 w-3 rounded-full\" style=\"background-color:#B7F46B;box-shadow:0 0 30px #B7F46B60, 0 0 60px #B7F46B20\"></div></div><div class=\"absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex items-center\" style=\"opacity:0\"><div class=\"h-px w-[200px] md:w-[300px]\" style=\"background:linear-gradient(90deg, transparent, #B7F46B20)\"></div><div class=\"w-6\"></div><div class=\"h-px w-[200px] md:w-[300px]\" style=\"background:linear-gradient(270deg, transparent, #B7F46B20)\"></div></div></div><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><!--/$--><div class=\"relative h-32 md:h-48 overflow-hidden\"><div class=\"absolute inset-0 flex items-center justify-center\" style=\"opacity:0;transform:scale(0.8)\"><div class=\"h-px w-[70%] max-w-2xl\" style=\"background:linear-gradient(90deg, transparent, #B7F46B30, #B7F46B15, #B7F46B30, transparent)\"></div></div><div class=\"absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[200px] w-[400px] rounded-full blur-3xl\" style=\"background:radial-gradient(ellipse, #B7F46B08 0%, transparent 70%);opacity:0\"></div></div><!--$--><section id=\"ai\" class=\"relative flex min-h-[100svh] flex-col justify-center py-8\"><div class=\"mx-auto max-w-6xl px-6\"><div class=\"mb-7 text-center md:mb-12\" style=\"opacity:0;transform:translateY(30px)\"><span class=\"mb-4 inline-block rounded-full border border-[#B7F46B]/20 bg-[#B7F46B]/5 px-4 py-1.5 text-[11px] font-semibold uppercase tracking-[0.2em] text-[#B7F46B]\">AI Superpowers</span><h2 class=\"mt-3 font-satoshi text-3xl font-black tracking-tight text-white md:mt-4 md:text-5xl\">Intelligence That<!-- --> <span class=\"bg-gradient-to-br from-[#B7F46B] to-[#6DAE2C] bg-clip-text text-transparent\">Works for You</span></h2></div><div class=\"mb-7 flex justify-center gap-2 md:mb-10 md:gap-3\"><button class=\"rounded-full border px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.15em] transition-all duration-300 md:px-6 md:text-xs\" style=\"border-color:#B7F46B50;color:#B7F46B;background:#B7F46B12\">Vision AI</button><button class=\"rounded-full border px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.15em] transition-all duration-300 md:px-6 md:text-xs\" style=\"border-color:rgba(255,255,255,0.08);color:rgba(255,255,255,0.4);background:transparent\">Smart Meal Planning</button><button class=\"rounded-full border px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.15em] transition-all duration-300 md:px-6 md:text-xs\" style=\"border-color:rgba(255,255,255,0.08);color:rgba(255,255,255,0.4);background:transparent\">Adaptive Intelligence</button></div><div class=\"flex flex-col items-center gap-8 md:flex-row md:gap-16\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex-1 text-center md:text-left\"><div class=\"mb-4 inline-flex items-center gap-2 rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.15em]\" style=\"background:#B7F46B10;color:#B7F46Bcc;border:1px solid #B7F46B20\">Vision AI</div><h3 class=\"font-satoshi text-2xl font-black text-white md:text-4xl\">See. Recognize. Calculate.</h3><p class=\"mx-auto mt-4 max-w-md text-sm leading-relaxed text-white/45 md:mx-0 md:text-base\">Point your camera at any food. Our computer vision instantly identifies ingredients, matches them against our nutrition database, and calculates precise macro breakdown — protein, fats, carbs, calories.</p></div><div class=\"relative flex flex-1 items-center justify-center\"><div class=\"relative w-[170px] md:w-[260px]\"><div class=\"overflow-hidden rounded-[2rem] border border-white/10 shadow-[0_20px_60px_rgba(0,0,0,0.5)]\"><img alt=\"Vision AI\" fetchPriority=\"high\" width=\"260\" height=\"563\" decoding=\"async\" data-nimg=\"1\" class=\"w-full\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fscreen-vision.PNG&amp;w=384&amp;q=75 1x, /_next/image?url=%2Fscreen-vision.PNG&amp;w=640&amp;q=75 2x\" src=\"/_next/image?url=%2Fscreen-vision.PNG&amp;w=640&amp;q=75\"/></div><div class=\"pointer-events-none absolute -inset-10 -z-10 rounded-full blur-3xl opacity-30\" style=\"background:radial-gradient(circle, #B7F46B40, transparent)\"></div></div></div></div></div></section><!--/$--><div class=\"relative h-24 md:h-32 overflow-hidden\"><div class=\"absolute inset-0 flex items-center justify-center gap-2\" style=\"opacity:0\"><div class=\"h-1 w-1 rounded-full\" style=\"background-color:#82AFFF;opacity:0.3\"></div><div class=\"h-1 w-1 rounded-full\" style=\"background-color:#82AFFF;opacity:0.3\"></div><div class=\"h-1 w-1 rounded-full\" style=\"background-color:#82AFFF;opacity:0.3\"></div></div></div><!--$--><section id=\"ecosystem\" class=\"relative flex min-h-[100svh] flex-col justify-center py-6\"><div aria-hidden=\"true\" class=\"sr-only\"><div><h3>Nutrition Intelligence</h3><p>Track every calorie and macro with precision. AI-powered food recognition analyzes your meals instantly from a single photo.</p><ul><li>Calories</li><li>Protein</li><li>Fats</li><li>Carbs</li></ul></div><div><h3>Fitness &amp; Activity</h3><p>Steps, workouts, runs, training videos, and multi-week marathon programs. Synced with Apple Health and Google Fit.</p><ul><li>Steps</li><li>Workouts</li><li>Distance</li><li>Active Min</li></ul></div><div><h3>Smart Hydration</h3><p>Intelligent water tracking with adaptive reminders that escalate based on urgency. Never forget to hydrate.</p><ul><li>Daily Goal</li><li>Intake</li><li>Reminders</li><li>History</li></ul></div><div><h3>AI Kitchen</h3><p>Smart fridge inventory, AI recipe suggestions from your ingredients, automatic meal planning, and shopping lists.</p><ul><li>Recipes</li><li>Ingredients</li><li>Meal Plans</li><li>Shopping</li></ul></div><div><h3>Deep Analytics</h3><p>Comprehensive progress tracking with custom date ranges, trend analysis, body metrics, and exportable insights.</p><ul><li>Weight</li><li>BMI</li><li>Trends</li><li>Reports</li></ul></div></div><div class=\"mx-auto max-w-6xl px-6\"><div class=\"mb-5 text-center md:mb-10\" style=\"opacity:0;transform:translateY(30px)\"><span class=\"mb-4 inline-block rounded-full border border-[#B7F46B]/20 bg-[#B7F46B]/5 px-4 py-1.5 text-[11px] font-semibold uppercase tracking-[0.2em] text-[#B7F46B]\">Ecosystem</span><h2 class=\"mt-4 font-satoshi text-3xl font-black tracking-tight text-white md:text-5xl\">One Platform.<br/><span class=\"bg-gradient-to-br from-[#B7F46B] to-[#6DAE2C] bg-clip-text text-transparent\">Five Dimensions.</span></h2><p class=\"mx-auto mt-4 hidden max-w-lg text-sm text-white/40 md:block md:text-base\">Everything you need for complete health management, unified in a single intelligent system.</p></div><div class=\"grid grid-cols-2 gap-3 md:hidden\"><div class=\"col-span-2\" style=\"touch-action:manipulation;opacity:0;transform:translateY(24px)\"><button style=\"touch-action:manipulation\" class=\"group relative flex w-full flex-col items-start gap-2.5 overflow-hidden rounded-xl border border-white/[0.07] bg-[linear-gradient(145deg,rgba(255,255,255,0.04),rgba(255,255,255,0.01))] p-4 text-left transition-transform duration-150 active:scale-[0.96] active:border-white/15\"><div class=\"absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent\"></div><span class=\"text-2xl\">🥗</span><div class=\"flex-1\"><div class=\"mb-