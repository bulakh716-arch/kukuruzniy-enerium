2:Tdca,{"@context":"https://schema.org","@graph":[{"@context":"https://schema.org","@type":"WebPage","name":"Enerium | AI Health App for Nutrition, Fitness & Wellness","url":"https://enerium.app","description":"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.","inLanguage":"en-US","isPartOf":{"@type":"WebSite","name":"Enerium","url":"https://enerium.app"}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is Enerium free to use?","acceptedAnswer":{"@type":"Answer","text":"Enerium offers a free tier with core features including calorie tracking, water reminders, and step counting. Premium unlocks AI meal planning, Vision AI food scanning, smart fridge management, and advanced analytics."}},{"@type":"Question","name":"How does Vision AI food recognition work?","acceptedAnswer":{"@type":"Answer","text":"Simply point your camera at any meal or food item. Our computer vision model identifies ingredients in real-time, matches them against our nutrition database of 900,000+ foods, and calculates precise macros — protein, fats, carbs, and calories."}},{"@type":"Question","name":"Does Enerium sync with Apple Health and Google Fit?","acceptedAnswer":{"@type":"Answer","text":"Yes. Enerium deeply integrates with Apple HealthKit and Google Fit. Steps, workouts, active minutes, and body metrics sync automatically in both directions."}},{"@type":"Question","name":"Can I use Enerium for meal planning?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. Our AI generates a complete weekly meal plan tailored to your calorie goals, dietary preferences, and the ingredients you already have at home. Each plan includes a ready-to-use shopping list."}},{"@type":"Question","name":"What is the Smart Fridge feature?","acceptedAnswer":{"@type":"Answer","text":"Smart Fridge lets you manage a virtual inventory of your real fridge and pantry. The AI then suggests recipes based on what you have, helping you reduce food waste and eat better without extra shopping."}},{"@type":"Question","name":"Is my health data private and secure?","acceptedAnswer":{"@type":"Answer","text":"Your privacy is our top priority. All health data is encrypted end-to-end and stored securely. We never sell your data to third parties. You can export or delete your data at any time."}}]},{"@context":"https://schema.org","@type":"ItemList","name":"Enerium App Features","description":"Five health dimensions powered by AI in the Enerium app","itemListElement":[{"@type":"ListItem","position":1,"name":"Nutrition Intelligence","description":"Track every calorie and macro with precision. AI-powered food recognition analyzes your meals instantly from a single photo."},{"@type":"ListItem","position":2,"name":"Fitness & Activity","description":"Steps, workouts, runs, training videos, and multi-week marathon programs. Synced with Apple Health and Google Fit."},{"@type":"ListItem","position":3,"name":"Smart Hydration","description":"Intelligent water tracking with adaptive reminders that escalate based on urgency. Never forget to hydrate."},{"@type":"ListItem","position":4,"name":"AI Kitchen","description":"Smart fridge inventory, AI recipe suggestions from your ingredients, automatic meal planning, and shopping lists."},{"@type":"ListItem","position":5,"name":"Deep Analytics","description":"Comprehensive progress tracking with custom date ranges, trend analysis, body metrics, and exportable insights."}]}]}10:T5a1,{"@context":"https://schema.org","@graph":[{"@context":"https://schema.org","@type":"Organization","name":"Enerium","url":"https://enerium.app","logo":"https://enerium.app/logo.png","description":"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.","email":"hello@enerium.app","contactPoint":[{"@type":"ContactPoint","contactType":"customer support","email":"hello@enerium.app","availableLanguage":["en"]},{"@type":"ContactPoint","contactType":"privacy support","email":"privacy@enerium.app","availableLanguage":["en"]},{"@type":"ContactPoint","contactType":"legal support","email":"legal@enerium.app","availableLanguage":["en"]}]},{"@context":"https://schema.org","@type":"WebSite","name":"Enerium","url":"https://enerium.app","description":"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.","inLanguage":"en-US"},{"@context":"https://schema.org","@type":"MobileApplication","name":"Enerium","url":"https://enerium.app","applicationCategory":"HealthApplication","operatingSystem":"iOS, Android","description":"AI-powered health app for nutrition tracking, meal planning, hydration reminders, fitness syncing, and wellness analytics in one platform.","featureList":["Nutrition Intelligence","Fitness & Activity","Smart Hydration","AI Kitchen","Deep Analytics"]}]}0:["bQfTIxRztHI02I1CVHvoY",[[["",{"children":["__PAGE__",{}]},"$undefined","$undefined",true],["",{"children":["__PAGE__",{},[["$L1",[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","main",null,{"className":"relative min-h-[100svh] overflow-x-hidden text-white","children":[["$","$L3",null,{}],["$","$L4",null,{}],["$","$L5",null,{}],["$","$L6",null,{"variant":"orb","color":"#B7F46B"}],["$","$7",null,{"fallback":null,"children":["$","$L8",null,{"reason":"next/dynamic","children":"$L9"}]}],["$","$L6",null,{"variant":"gradient","color":"#B7F46B"}],["$","$7",null,{"fallback":null,"children":[["$","$La",null,{"moduleIds":["app/page.tsx -> @/components/sections/AISuperSection"]}],"$Lb"]}],["$","$L6",null,{"variant":"dots","color":"#82AFFF"}],["$","$7",null,{"fallback":null,"children":[["$","$La",null,{"moduleIds":["app/page.tsx -> @/components/sections/EcosystemSection"]}],"$Lc"]}],["$","$L6",null,{"variant":"gradient","color":"#B7F46B"}],["$","$7",null,{"fal